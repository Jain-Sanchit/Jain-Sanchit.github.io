---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {SITE_AUTHOR}. All reviews based on personal trips and statements.</p>
	<p class="links">
		<a href="/">Home</a>
		<a href="/blog/">Blog</a>
		<a href="/about/">About</a>
	</p>
	<p class="meta">{SITE_TITLE} is an independent travel blog and is not affiliated with Niyo, Scapia, Federal Bank, or any card issuer.</p>
</footer>
<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.95em;
	}
	footer p {
		margin: 0.5em 0;
	}
	.links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
	}
	.links a {
		color: rgb(var(--gray-dark));
	}
	.meta {
		font-size: 0.85em;
		opacity: 0.8;
		max-width: 540px;
		margin-left: auto;
		margin-right: auto;
	}
</style>
